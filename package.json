{
    "name": "circuitscript",
    "version": "0.0.22",
    "description": "Interpreter for the circuitscript language",
    "homepage": "https://circuitscript.net",
    "engines": {
        "node": ">=16.0"
    },
    "type": "module",
    "main": "./build/src/main.js",
    "bin": {
        "circuitscript": "./build/src/main.js"
    },
    "devDependencies": {
        "@types/figlet": "^1.5.8",
        "@types/jest": "~29.5",
        "@types/node": "~18",
        "@types/svgdom": "^0.1.2",
        "@typescript-eslint/eslint-plugin": "~5.59",
        "@typescript-eslint/parser": "~5.59",
        "eslint": "~8.38",
        "eslint-config-prettier": "~8.8",
        "eslint-plugin-jest": "~27.2",
        "jest": "~29.5",
        "prettier": "~2.8",
        "rimraf": "~5.0",
        "source-map-support": "^0.5.21",
        "ts-api-utils": "~0.0.44",
        "ts-jest": "~29.1",
        "typescript": "^5.4.5"
    },
    "scripts": {
        "start": "node build/src/main.js",
        "clean": "rimraf coverage build tmp",
        "build": "tsc -p tsconfig.json",
        "build:watch": "tsc -w -p tsconfig.json",
        "build:release": "npm run clean && tsc -p tsconfig.release.json",
        "prebuild": "npm run lint",
        "lint": "eslint . --ext .ts --ext .mts",
        "test": "jest",
        "test-coverage": "jest --coverage",
        "prettier": "prettier --config .prettierrc --write .",
        "test:watch": "jest --watch",
        "antlr": "antlr4 -Dlanguage=TypeScript ./src/antlr/CircuitScript.g4 -no-listener -visitor",
        "profile": "node --prof build/src/main.js examples/example_garden_pump.cst",
        "profile-flame": "node --prof-process --preprocess -j isolate*.log | flamebearer",
        "server": "node server.js"
    },
    "boilerplate_author": "Jakub Synowiec <jsynowiec@users.noreply.github.com>",
    "license": "MIT",
    "dependencies": {
        "@dagrejs/graphlib": "^2.1.13",
        "@flatten-js/core": "^1.4.3",
        "@svgdotjs/svg.js": "^3.2.0",
        "antlr4": "^4.13.0",
        "commander": "^11.1.0",
        "express": "^4.18.2",
        "figlet": "^1.7.0",
        "lodash": "^4.17.21",
        "svgdom": "^0.1.14",
        "tslib": "~2.5",
        "ws": "^8.14.2"
    },
    "volta": {
        "node": "18.12.1"
    }
}
