{
    "name": "circuitscript",
    "version": "0.1.0",
    "description": "Interpreter for the circuitscript language",
    "homepage": "https://circuitscript.net",
    "engines": {
        "node": ">=16.0"
    },
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/types/index.d.ts",
    "bin": {
        "circuitscript": "./dist/cjs/main.js"
    },
    "exports": {
        ".": {
            "require": "./dist/cjs/index.js",
            "import": "./dist/esm/index.mjs"
        }
    },
    "files": [
        "dist",
        "fonts",
        "libs"
    ],
    "devDependencies": {
        "@types/figlet": "^1.5.8",
        "@types/jest": "~29.5",
        "@types/node": "~18",
        "@types/pdfkit": "^0.13.6",
        "@types/svg-to-pdfkit": "^0.1.3",
        "@types/svgdom": "^0.1.2",
        "@typescript-eslint/eslint-plugin": "~5.59",
        "@typescript-eslint/parser": "~5.59",
        "antlr4ng-cli": "^2.0.0",
        "eslint": "~8.38",
        "eslint-config-prettier": "~8.8",
        "eslint-plugin-jest": "~27.2",
        "jest": "~29.5",
        "prettier": "~2.8",
        "rimraf": "~5.0",
        "source-map-support": "^0.5.21",
        "ts-api-utils": "~0.0.44",
        "ts-jest": "~29.1",
        "ts2mjs": "^3.0.0",
        "typescript": "^5.4.5"
    },
    "scripts": {
        "start": "node build/src/main.js",
        "clean": "rimraf coverage build tmp dist",
        "build": "npm run build:cjs || npm run build:esm",
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build:release:cjs": "tsc -p tsconfig.release.cjs.json",
        "build:esm": "tsc -p tsconfig.esm.json || npm run rename:esm",
        "build:release:esm": "tsc -p tsconfig.release.esm.json || npm run rename:esm",
        "rename:esm": "npx ts2mjs ./dist/esm && rm -rf ./dist/esm/*.js && rm -rf ./dist/esm/**/*.js",
        "build:watch": "tsc -w -p tsconfig.esm.json",
        "build:watch:cjs": "tsc -w -p tsconfig.cjs.json",
        "build:release": "npm run clean && npm run build:release:cjs || npm run build:release:esm",
        "prebuild": "npm run lint || true",
        "lint": "eslint . --ext .ts --ext .mts",
        "test": "jest",
        "test-coverage": "jest --coverage",
        "prettier": "prettier --config .prettierrc --write .",
        "test:watch": "jest --watch",
        "antlr": "antlr4 -Dlanguage=TypeScript ./src/antlr/CircuitScript.g4 -no-listener -visitor",
        "antlr4ng": "npx antlr4ng -Dlanguage=TypeScript -o src/antlr -visitor -no-listener -Xexact-output-dir src/antlr/CircuitScript.g4",
        "profile": "node --prof build/src/main.js examples/example_garden_pump.cst",
        "profile-flame": "node --prof-process --preprocess -j isolate*.log | flamebearer",
        "server": "node server.js",
        "pack-local": "npm pack; rm circuitscript-install.tgz; mv `ls | grep circuitscript` circuitscript-install.tgz; cp circuitscript-install.tgz ../circuitscript-vscode/client; cp circuitscript-install.tgz ../circuitscript-vscode/server",
        "changelog": "auto-changelog --handlebars-setup ../changelog/helper.js"
    },
    "boilerplate_author": "Jakub Synowiec <jsynowiec@users.noreply.github.com>",
    "license": "MIT",
    "dependencies": {
        "@dagrejs/graphlib": "2.1.13",
        "@flatten-js/core": "1.5.5",
        "@svgdotjs/svg.js": "3.2.0",
        "antlr4ng": "^3.0.4",
        "commander": "^11.1.0",
        "express": "^4.18.2",
        "figlet": "^1.7.0",
        "lodash": "^4.17.21",
        "pdfkit": "^0.15.1",
        "svg-to-pdfkit": "^0.1.8",
        "svgdom": "0.1.14",
        "this-file": "^2.0.3",
        "tslib": "~2.5",
        "ws": "^8.14.2"
    },
    "volta": {
        "node": "18.12.1"
    },
    "auto-changelog": {
        "output": "CHANGELOG.md",
        "commitLimit": false,
        "template": "../changelog/template.hbs"
    }
}
