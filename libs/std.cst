# Circuitscript default lib

def net(net_name, net_type = "any"):
    return create component:
        pins: 1
        copy: true
        display: create graphic (params):
            hline: -50, 0, 100
            vpin: 1, 0, 50, -50, display_id=false
            label: params.net_name, 0, -15, name="value", fontSize=50, anchor="center"
        type: "net"
        params:
            net_name: net_name
            priority: 10
            net_type: net_type

def supply(net_name):
    net_obj = net(net_name, "source")
    return net_obj

def label(value, anchor="left"):
    return create component:
        pins: 1
        copy: true
        followWireOrientation: false
        display: create graphic (params):
            text_color: "#222"
            label: params.value, 0, -10, name="value", fontSize=50, anchor=anchor
            pin: 1, 0, 0, 0, 0, display_id=false
        type: "net"
        is_label: true
        params:
            net_name: value
            value: value
            priority: 5

def port(value, portType="input"):
    return create component:
        pins: 1
        copy: true
        display: create graphic (params):
            text_color: "#222"
            label: params.value, 0, 0, name="value", fontSize=40, anchor="left", vanchor="center", portType=portType
            pin: 1, 0, 0, 0, 0, display_id=false
        type: "port"
        params:
            net_name: value
            value: value
            priority: 5

def res(value):
    width = 140
    height = 60
 
    return create component:
        pins: 2
        display: create graphic (params):
            crect: 0, 0, width, height
            hpin: 1, -width/2 - 30, 0, 30, display_id=false
            hpin: 2, width/2 + 30, 0, -30, display_id=false
            label: params.refdes, -width/2 + params.refdes_offsetx, -height/2 - 20 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left"
            label: params.value, 0, 0, name="value", fontSize=30, anchor="center", vanchor="center"
        type: "res"
        params:
            value: value
            size: "0402"
            footprint: "Resistor_SMD:R_0402_1005Metric"
            description: "RES {value} OHM {size}"
            refdes_offsetx: 0
            refdes_offsety: 0

def cap(value):
    width = 120
    height = 40

    return create component:
        pins: 2
        display: create graphic (params):
            line_width: 13
            hline: -width/2, 20, width
            hline: -width/2, -20, width
            vpin: 1, 0, -100, 80, display_id=false
            vpin: 2, 0, 100, -80, display_id=false
            label: params.refdes, 80 + params.refdes_offsetx, -30 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left", vanchor="center"
            label: params.value, 80, 30, name="value", fontSize=50, anchor = "left", vanchor="center"
        type: "cap"
        params:
            value: value
            size: "0402"
            footprint: "Capacitor_SMD:C_0402_1005Metric"
            refdes_offsetx: 0
            refdes_offsety: 0

def ind(value):
    width = 200
    height = 100

    return create component:
        pins: 2
        type: "ind"
        display: create graphic (params):
            arc: -75, 0, 25, 180, 360
            arc: -25, 0, 25, 180, 360
            arc: 25, 0, 25, 180, 360
            arc: 75, 0, 25, 180, 360
            hpin: 1, -width/2 - 100, 0, 100, display_id=false
            hpin: 2, width/2 + 100, 0, -100, display_id=false
            label: (params.refdes, -width/2 + params.refdes_offsetx, -height/2 - 25 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left")
            label: (params.value, 0, 50, name="value", fontSize=50, anchor="center", vanchor="center")
        params:
            value: value
            refdes_offsetx: 0
            refdes_offsety: 0

def diode():
    width = 100
    height = 100

    # Diode is drawn horizontally
    #  -|>|-
    return create component:
        pins: 2
        type: "diode"
        display: create graphic (params):
            triangle: -width/2, 0, width/2, 0, height
            vline: width/2, -height/2, height
            hpin: 1, -width/2-100, 0, 100    # cathode
            hpin: 2, width/2 + 100, 0, -100  # anode
            label: params.refdes, 0 + params.refdes_offsetx, -100 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="top"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def led(color):
    width = 100
    height = 100

    # anode and cathode pin numbers follow KiCad
    return create component:
        type: "diode"
        display: create graphic (params):
            triangle: -width/2, 0, width/2, 0, height
            vline: width/2, -height/2, height
            arrow: 70, 30, 130, 90, 25, 25
            arrow: 120, 30, 180, 90, 25, 25

            hpin: 1, "C", width/2 + 100, 0, -100, display_name=false  # cathode
            hpin: 2, "A", -width/2-100, 0, 100, display_name=false    # anode
            label: params.refdes, 0 + params.refdes_offsetx, -100 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="top"
            label: params.color, 0, 100, fontSize=40, anchor="center", vanchor="bottom"
        params:
            size: "0603"
            color: color
            value: color
            footprint: "LED_SMD:LED_0603_1608Metric_Pad1.05x0.95mm_HandSolder"
            description: "LED {color} {size}"
            refdes_offsetx: 0
            refdes_offsety: 0

def cgnd():
    net_name = "gnd"
    return create component:
        pins: 1
        copy: true
        display: create graphic (params):
            hline: -15, 0, 30
            hline: -10, 5, 20
            hline: -5, 10, 10
            vpin: 1, 0, -10, 10, display_id=false
            label: params.net_name, 0, 22, name="value", fontSize=50, anchor="center"
        type: "net"
        params:
            net_name: net_name
            priority: 100

def dgnd(net_name="GND"):
    height = 50
    width = 100

    return create component:
        pins: 1
        copy: true
        display: create graphic (params):
            triangle: 0, 0, 0, height, width
            vpin: 1, 0, -50, 50, display_id=false
            label: params.net_name, 0, height + 50, name="value", fontSize=50, anchor="center", vanchor="center"
        type: "net"
        params:
            net_name: net_name
            priority: 100

def text(value, offsetX = 0, offsetY = 0, fontSize = 50, bold = false, italic = false):
    return create component:
        pins: 1
        followWireOrientation: false
        type: "graphic"
        display: create graphic:
            pin: 1, 0, 0, 0, 0, display_id=false
            text:
                content: value
                offset: offsetX, offsetY
                fontSize: fontSize
                bold: bold
                italic: italic

# Drawing markers

def marker_point():
    return create component:
        pins: 1
        display: create graphic:
            hline: -5, 0, 10
            vline: 0, -5, 10
            pin: 1, 0, 0, 0, 0, display_id=false

def arrow_point():
    return create component:
        pins: 1
        followWireOrientation: false
        display: create graphic:
            line_width: 2
            path: ("M", -10, -5, "L", -5, 0, "L", -10, 5)
            path: ("M", -5, 0, "L", -20, 0)
            hpin: 1, 0, 0, 0, display_id=false

def no_connect(size=20):
    return create component:
        pins: 1
        type: "graphic"
        display: create graphic:
            path: "M", -size, -size, "L", size, size
            path: "M", -size, size, "L", size, -size
            pin: 1, 0, 0, 0, 0, display_id=false
        params:
            no_connect: true

def dnc(size=20):
    return no_connect(size)

# ============================================================
# Passive Components
# ============================================================

def pot(value):
    # Potentiometer — 3 pins: pin1 (end1), pin2 (end2), pin3 (wiper)
    width = 140
    height = 60

    return create component:
        pins: 3
        type: "res"
        display: create graphic (params):
            crect: 0, 0, width, height
            hpin: 1, -width/2 - 30, 0, 30, display_id=false
            hpin: 2, width/2 + 30, 0, -30, display_id=false
            vpin: 3, 0, height/2 + 80, -80, display_id=false
            # Arrowhead pointing up toward body (wiper indicator)
            path: ("M", -12, height/2 + 14, "L", 0, height/2, "L", 12, height/2 + 14)
            label: params.refdes, -width/2 + params.refdes_offsetx, -height/2 - 20 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left"
            label: params.value, 0, 0, name="value", fontSize=30, anchor="center", vanchor="center"
        params:
            value: value
            refdes_offsetx: 0
            refdes_offsety: 0

def cap_pol(value):
    # Polarized capacitor (electrolytic) — pin1 (+anode), pin2 (-cathode)
    width = 120
    height = 40

    return create component:
        pins: 2
        type: "cap"
        display: create graphic (params):
            line_width: 13
            hline: -width/2, 20, width
            hline: -width/2, -20, width
            vpin: 1, 0, -100, 80, display_id=false
            vpin: 2, 0, 100, -80, display_id=false
            # Plus sign near positive (top) plate
            line_width: 8
            hline: -50, -50, 30
            vline: -35, -65, 30
            label: params.refdes, 80 + params.refdes_offsetx, -30 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left", vanchor="center"
            label: params.value, 80, 30, name="value", fontSize=50, anchor="left", vanchor="center"
        params:
            value: value
            size: "0402"
            footprint: "Capacitor_SMD:CP_Elec_3x5.3"
            refdes_offsetx: 0
            refdes_offsety: 0

def ferrite(value):
    # Ferrite bead — filled rectangle body
    width = 140
    height = 60

    return create component:
        pins: 2
        type: "ind"
        display: create graphic (params):
            fill: "#333"
            crect: 0, 0, width, height
            fill: "none"
            hpin: 1, -width/2 - 30, 0, 30, display_id=false
            hpin: 2, width/2 + 30, 0, -30, display_id=false
            label: params.refdes, -width/2 + params.refdes_offsetx, -height/2 - 20 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left"
        params:
            value: value
            refdes_offsetx: 0
            refdes_offsety: 0

def xtal(frequency):
    # Crystal oscillator — 2-pin
    width = 80
    height = 160

    return create component:
        type: "X"
        pins: 2
        display: create graphic (params):
            # Piezoelectric plates (thick vertical lines)
            line_width: 14
            vline: -12, -height/2, height
            vline: 12, -height/2, height
            # Outer case
            line_width: 5
            crect: 0, 0, width, height
            hpin: 1, -width/2 - 120, 0, 120, display_id=false
            hpin: 2, width/2 + 120, 0, -120, display_id=false
            label: params.refdes, 0 + params.refdes_offsetx, -height/2 - 20 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="bottom"
            label: params.frequency, 0, height/2 + 20, fontSize=50, anchor="center", vanchor="top"
        params:
            frequency: frequency
            refdes_offsetx: 0
            refdes_offsety: 0

def fuse(value):
    # Fuse — rectangle with center line
    width = 140
    height = 60

    return create component:
        pins: 2
        type: "F"
        display: create graphic (params):
            crect: 0, 0, width, height
            hline: -width/2, 0, width
            hpin: 1, -width/2 - 30, 0, 30, display_id=false
            hpin: 2, width/2 + 30, 0, -30, display_id=false
            label: params.refdes, -width/2 + params.refdes_offsetx, -height/2 - 20 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left"
            label: params.value, 0, 0, name="value", fontSize=30, anchor="center", vanchor="center"
        params:
            value: value
            refdes_offsetx: 0
            refdes_offsety: 0

def jumper():
    # Jumper / solder bridge — 2 pads with arc
    return create component:
        pins: 2
        type: "jp"
        display: create graphic (params):
            circle: -50, 0, 20
            circle: 50, 0, 20
            arc: 0, 0, 50, 180, 360
            hpin: 1, -150, 0, 100, display_id=false
            hpin: 2, 150, 0, -100, display_id=false
            label: params.refdes, 0 + params.refdes_offsetx, -80 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="bottom"
        params:
            refdes_prefix: "JP"
            refdes_offsetx: 0
            refdes_offsety: 0

# ============================================================
# Diodes
# ============================================================

def zener():
    # Zener diode — pin1 (cathode), pin2 (anode)
    width = 100
    height = 100

    return create component:
        pins: 2
        type: "diode"
        display: create graphic (params):
            triangle: -width/2, 0, width/2, 0, height
            vline: width/2, -height/2, height
            # Zener wings (bent ends on cathode bar)
            line: width/2, -height/2, width/2-20, -height/2-20
            line: width/2, height/2, width/2 + 20, height/2 + 20
            hpin: 1, -width/2 - 100, 0, 100, display_id=false
            hpin: 2, width/2 + 100, 0, -100, display_id=false
            label: params.refdes, -20- params.refdes_offsetx, -110 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="top"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def schottky():
    # Schottky diode — pin1 (cathode), pin2 (anode)
    width = 100
    height = 100

    return create component:
        pins: 2
        type: "diode"
        display: create graphic (params):
            triangle: -width/2, 0, width/2, 0, height
            vline: width/2, -height/2, height
            # Schottky S-curve marks on cathode bar
            path: ("M", width/2, -height/2, "L", width/2 - 20, -height/2, "L", width/2 - 20, -height/2 + 20)
            path: ("M", width/2, height/2, "L", width/2 + 20, height/2, "L", width/2 + 20, height/2 - 20)
            hpin: 1, -width/2 - 100, 0, 100, display_id=false
            hpin: 2, width/2 + 100, 0, -100, display_id=false
            label: params.refdes, 0 + params.refdes_offsetx, -100 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="top"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def tvs():
    # TVS (transient voltage suppressor) — bidirectional zener
    # pin1 (A1), pin2 (A2)
    width = 100
    height = 100

    return create component:
        pins: 2
        type: "diode"
        display: create graphic (params):
            # Two back-to-back diode triangles
            triangle: -width/2, 0, width/2, 0, height
            vline: width/2, -height/2, height
            hline: width/2, -height/2, 20
            hline: width/2 - 20, height/2, 20
            #triangle: width/2, 0, -width/2, 0, height
            #vline: -width/2, -height/2, height
            #hline: -width/2, -height/2, -20
            #hline: -width/2 + 20, height/2, -20
            hpin: 1, -width/2 - 100, 0, 100, display_id=false
            hpin: 2, width/2 + 100, 0, -100, display_id=false
            label: params.refdes, 0 + params.refdes_offsetx, -100 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="top"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def photodiode():
    # Photodiode — arrows pointing inward (light detecting)
    # pin1 (cathode), pin2 (anode)
    width = 100
    height = 100

    return create component:
        pins: 2
        type: "diode"
        display: create graphic (params):
            triangle: -width/2, 0, width/2, 0, height
            vline: width/2, -height/2, height
            # Light arrows pointing toward junction

            arrow: -25, 95, 25, 45, 25, 25
            arrow: -25, 145, 25, 95, 25, 25

            #path: ("M", -25, 125, "L", 25, 75, "M", 25, 100, "L", 25, 75, "L", 0, 75)
            #path: ("M", -75, 125, "L", -25, 75, "M", -25, 100, "L", -25, 75, "L", -50, 75)

            hpin: 1, -width/2 - 100, 0, 100, display_id=false
            hpin: 2, width/2 + 100, 0, -100, display_id=false
            label: params.refdes, 0 + params.refdes_offsetx, -100 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="top"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

# ============================================================
# Transistors
# ============================================================

def npn():
    # NPN BJT — pin1 (B), pin2 (C), pin3 (E)
    return create component:
        pins:
            1: "B"
            2: "C"
            3: "E"
        type: "transistor"
        display: create graphic (params):
            # Base bar
            line_width: 15
            vline: -25, -80, 160
            line_width: 5
            # Collector diagonal (upper)
            line: -20, -40, 60, -100
            # Emitter diagonal (lower)
            arrow: -20, 40, 60, 100, 25, 25

            # Emitter arrow — NPN: outward (away from base)

            hpin: 1, -120, 0, 100, display_id=false     # base
            vpin: 2, 60, -200, 100, display_id=false    # collector
            vpin: 3, 60, 200, -100, display_id=false    # emitter
            label: params.refdes, 70 + params.refdes_offsetx, 0 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left", vanchor="center"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def pnp():
    # PNP BJT — pin1 (B), pin2 (C), pin3 (E)
    return create component:
        pins:
            1: "B"
            2: "C"
            3: "E"
        type: "transistor"
        display: create graphic (params):
            # Base bar
            line_width: 15
            vline: -25, -80, 160
            line_width:5

            # Collector diagonal (upper)
            line: -20, -40, 60, -100
            # Emitter diagonal (lower)
            #line: -20, 40, 60, 100
            # Emitter arrow — PNP: inward (toward base bar)
            arrow:60, 100, -20, 40
            hpin: 1, -120, 0, 100, display_id=false
            vpin: 2, 60, -200, 100, display_id=false
            vpin: 3, 60, 200, -100, display_id=false
            label: params.refdes, 70 + params.refdes_offsetx, 0 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left", vanchor="center"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def pmos():
    return create component:
        pins: 3
        type: "Q"
        display: create graphic (params):
            hline: -75, -25, 175
            fill: "#333"
            crect: 0, 0, 50, 15
            crect: 75, 0, 50, 15
            crect: -75, 0, 50, 15
            vline: 75, 0, 100
            vline: -75, 0, 100
            
            arrow: 0, 0, 0, 90
            vline: 0, 0, 100
            
            hline: 0, 100, -100
            hline: 100, 100, -25
            
            path: "M", -100, 100, "L", -100, 150, "L", 100, 150, "L", 100, 100
            arrow: 100, 150, -12.5,150
            vline: -12.5, 150-20, 40

            label: params.refdes, 70, -60, name="refdes", anchor="center"
            label: params.mpn, 0, 250, anchor="center"

            hpin: 1, "D", 200, 100, -100, display_id=false, display_name=false
            vpin: 2, "G", 0, -100, 75, display_id=false, display_name=false
            hpin: 3, "S", -200, 100, 100, display_id=false, display_name=false

            label: "S", -200, 70
            label: "D", 200, 70, anchor="right"
            label: "G", -70, -50
        params:
            mpn: "?"

def nmos():
    return create component:
        pins: 3
        type: "Q"
        display: create graphic (params):
            hline: -75, -25, 175
            fill: "#333"
            crect: 0, 0, 50, 15
            crect: 75, 0, 50, 15
            crect: -75, 0, 50, 15
            vline: 75, 0, 100
            vline: -75, 0, 100
            
            arrow: 0, 100, 0, 20
            vline: 0, 0, 100
            
            hline: 0, 100, -100
            hline: 100, 100, -25

            path: "M", -100, 100, "L", -100, 150, "L", 100, 150, "L", 100, 100
            arrow: -100, 150, 12.5,150
            vline: 12.5, 150-20, 40

            label: params.refdes, 70, -60, name="refdes", anchor="center"
            label: params.mpn, 0, 250, anchor="center"

            hpin: 1, "D", 200, 100, -100, display_id=false, display_name=false
            vpin: 2, "G", 0, -100, 75, display_id=false, display_name=false
            hpin: 3, "S", -200, 100, 100, display_id=false, display_name=false

            label: "S", -200, 70
            label: "D", 200, 70, anchor="right"
            label: "G", -70, -50
        params:
            mpn: "?"

# ============================================================
# Integrated Circuits
# ============================================================

def opamp():
    # Op-amp — pin1 (OUT), pin2 (-), pin3 (+)
    width = 200
    height = 200

    return create component:
        type: "ic"
        display: create graphic (params):
            triangle: -width/2, 0, width/2, 0, height
            hpin: 1, "OUT", width/2 + 100, 0, -100, display_id=false, display_name = false
            hpin: 2, "-", -width/2 - 100, 50, 100, display_id=false
            hpin: 3, "+", -width/2 - 100, -50, 100, display_id=false
            label: params.refdes, 0 + params.refdes_offsetx, -height/2 - 20 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="bottom"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def comparator():
    # Comparator — pin1 (OUT), pin2 (-), pin3 (+)
    # Same triangle symbol as opamp; open-collector output indication
    width = 200
    height = 200

    return create component:
        type: "ic"
        display: create graphic (params):
            triangle: -width/2, 0, width/2, 0, height
            hpin: 1, "OUT", width/2 + 100, 0, -100, display_id=false, display_name = false
            hpin: 2, "-", -width/2 - 100, 50, 100, display_id=false
            hpin: 3, "+", -width/2 - 100, -50, 100, display_id=false
            # Open-collector circle at output
            circle: width/2 + 15, 0, 15
            label: params.refdes, 0 + params.refdes_offsetx, -height/2 - 20 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="bottom"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

# ============================================================
# Switches and Connectors
# ============================================================

def switch_spst():
    # Single-pole single-throw switch (normally open)
    return create component:
        pins: 2
        type: "SW"
        display: create graphic (params):
            circle: -60, 0, 12
            circle: 60, 0, 12
            # Open switch line (diagonal)
            line: -48, 0, 45, -60
            hpin: 1, -160, 0, 100, display_id=false
            hpin: 2, 160, 0, -100, display_id=false
            label: params.refdes, 0 + params.refdes_offsetx, -80 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="bottom"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def switch_pb():
    # Normally-open push button
    return create component:
        pins: 2
        type: "SW"
        display: create graphic (params):
            # Contact circles
            circle: -60, 20, 12
            circle: 60, 20, 12
            # Actuator bar (above)
            hline: -70, -30, 140
            # Push shaft
            # Arrowhead pointing down (push direction)

            arrow: 0, -90, 0, -35

            hpin: 1, -160, 20, 100, display_id=false
            hpin: 2, 160, 20, -100, display_id=false
            label: params.refdes, 0 + params.refdes_offsetx, -100 + params.refdes_offsety, name="refdes", fontSize=50, anchor="center", vanchor="bottom"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def conn_single_row(num_pins):
    # Generic N-pin connector — all pins on left side
    # pin 1 is used as the symbol origin

    return create component:
        type: "conn"
        pins: num_pins
        display: create graphic (params):
            rect: -100, -100, 200, (num_pins-1) * 100 + 200

            for i in range(0, num_pins):
                circle: 0, i * 100, 40
                hpin: (i+1), -200, i * 100,   160

            label: params.refdes, -20 + params.refdes_offsetx, -125 + params.refdes_offsety, name="refdes", align="center"
            #label: "mpn", -20, 20 + 4, "?", vanchor="top"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0
            
def conn_double_rows(num_pins, pin_order = "sequence"):
    # Generic N-pin double-row connector — half pins on left side, half on right
    # pin_order: "sequence" (left=1..N/2, right=N/2+1..N),
    #            "zig-zag"  (left=1,3,5,.., right=2,4,6,..),
    #            "down-up"  (left=1..N/2, right=N..N/2+1)
    
    if num_pins % 2 != 0:
        num_pins += 1

    half = num_pins / 2
    left_pins = []
    right_pins = []

    for i in range(0, half):
        if pin_order == "zig-zag":
            array_push(left_pins, i * 2 + 1)
            array_push(right_pins, i * 2 + 2)
        else if pin_order == "down-up":
            array_push(left_pins, i + 1)
            array_push(right_pins, num_pins - i)
        else:
            array_push(left_pins, i + 1)
            array_push(right_pins, half + i + 1)

    return create component:
        type: "conn"
        pins: num_pins
        display: create graphic (params):
            rect: -100, -100, 200, (half-1) * 100 + 200

            for i in range(0, half):
                circle: -45, i * 100, 30
                circle: 45, i * 100, 30
                hpin: array_get(left_pins, i), -200, i * 100, 100
                hpin: array_get(right_pins, i), 200, i * 100, -100

            label: params.refdes, -20 + params.refdes_offsetx, -125 + params.refdes_offsety, name="refdes", align="center"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0


# ============================================================
# Test / Annotation
# ============================================================

def test_point():
    # Test point — single-pin circle marker
    return create component:
        pins: 1
        type: "TP"
        display: create graphic (params):
            circle: 0, -20, 20
            vpin: 1, 0, 100, -100, display_id=false
            label: params.refdes, 40 + params.refdes_offsetx, -20 + params.refdes_offsety, name="refdes", fontSize=50, anchor="left", vanchor="center"
        params:
            refdes_offsetx: 0
            refdes_offsety: 0

def sheet_generator(paper_size_name, paper_width, paper_height, margin_x, margin_y, 
    col_display_value, row_display_value, inner_frame_margin = 50):
    
    horizontal_1 = margin_x - inner_frame_margin
    horizontal_2 = paper_width - margin_x + inner_frame_margin

    vertical_1 = margin_y - inner_frame_margin
    vertical_2 = paper_height - margin_y + inner_frame_margin

    inner_width = paper_width - 2 * margin_x
    inner_height = paper_height - 2 * margin_y

    tmp_height = paper_height - margin_y * 2 + inner_frame_margin * 2
    tmp_y = margin_y - inner_frame_margin

    tmp_width = paper_width - margin_x * 2 + inner_frame_margin * 2
    tmp_x = margin_x - inner_frame_margin

    fontSize = 30

    num_columns = len(col_display_value)
    num_rows = len(row_display_value)

    ratio_x = 1 / num_columns
    ratio_y = 1 / num_rows

    title_block_width = 2000
    title_block_height = 350

    # center of title_block
    title_block_x = margin_x + inner_width - title_block_width
    title_block_y = margin_y + inner_height - title_block_height

    title_block_x2 = title_block_x + title_block_width
    title_block_y2 = title_block_y + title_block_height

    return create component:
        type: "graphic"
        display: create graphic (params):
            fill: "none"

            # outer rect 
            line_color: "#cccccc"
            crect: (paper_width/2, paper_height/2, 
                paper_width, paper_height, class="paper-area")

            # inner rect
            line_color: "#111111"
            crect: (paper_width/2, paper_height/2, 
                    inner_width, inner_height, class="plot-area")

            crect: (paper_width/2, paper_height/2, 
                    paper_width - 2 * margin_x + inner_frame_margin * 2, 
                    paper_height - 2 * margin_y  + inner_frame_margin * 2)

            for i in range(1, num_rows):
                hline: horizontal_1, (tmp_y + tmp_height * ratio_y * i), inner_frame_margin
                hline: horizontal_2, (tmp_y + tmp_height * ratio_y * i), -inner_frame_margin

            for i in range(1, num_columns):
                vline: (tmp_x + tmp_width * ratio_x * i),     vertical_1, inner_frame_margin
                vline: (tmp_x + tmp_width * ratio_x * i),     vertical_2, -inner_frame_margin

            # labels on the columns
            for i in col_display_value:
                text: 
                    content: i
                    offset: tmp_x + tmp_width * ratio_x * (0.5 + (i-1)), tmp_y + inner_frame_margin * 0.5 + 2
                    fontSize: fontSize
                    anchor: "center"
                    vanchor: "center"

                text: 
                    content: i
                    offset: tmp_x + tmp_width * ratio_x * (0.5 + (i-1)), tmp_y + tmp_height - inner_frame_margin * 0.5 + 2
                    fontSize: fontSize
                    anchor: "center"
                    vanchor: "center"

            for index, val in enumerate(row_display_value):
                text: 
                    content: val
                    offset: tmp_x + inner_frame_margin * 0.5, tmp_y + tmp_height * ratio_y * (0.5 + index)
                    fontSize: fontSize
                    anchor: "center"
                    vanchor: "center"

                text: 
                    content: val
                    offset: tmp_x + tmp_width - inner_frame_margin * 0.5, tmp_y + tmp_height * ratio_y * (0.5 + index)
                    fontSize: fontSize
                    anchor: "center"
                    vanchor: "center"

            # Draw title frame
            text: 
                content: "Size: " + paper_size_name
                offset: title_block_x + 20, title_block_y2 - 30
                anchor: "left"
                vanchor: "bottom"

            text:
                content: "Sheet: " + params.sheet_number + "/" + params.sheet_total
                anchor: "left"
                vanchor: "bottom"
                offset: title_block_x + title_block_width / 2 + 20, title_block_y2 - 30

            hline: title_block_x, title_block_y2 - 100, title_block_width
            vline: title_block_x + title_block_width / 2, title_block_y2, -100

            text:
                content: "Rev: " + params.revision
                anchor: "left"
                vanchor: "bottom"
                offset: title_block_x + 20 , title_block_y2 - 130

            hline: title_block_x, title_block_y2 - 200, title_block_width

            text: 
                content: params.title
                offset: title_block_x + 20, title_block_y2 - 240
                bold: true
                fontSize: 60
                anchor: "left"
                vanchor: "bottom"

            crect: (title_block_x + title_block_width / 2, 
                    title_block_y + title_block_height / 2, 
                    title_block_width, title_block_height,
                    class="keepout-area")

        params:
            title: "Sheet title"
            revision: "V1"
            sheet_number: 1
            sheet_total: 1

            paper_size: paper_size_name
            paper_width: paper_width
            paper_height: paper_height
            
            offset_x: margin_x
            offset_y: margin_y
            
            grid_width: paper_width - 2 * margin_x
            grid_height: paper_height - 2 * margin_y

def sheet_A1():
    paper_width = to_mils(841)
    paper_height = to_mils(594)
    margin = 400

    return sheet_generator("A1", paper_width, paper_height, margin, margin, 
        range(1, 17), ["A", "B", "C", "D", "E", "F", "G", "H", "I", "J", "K", "L"])

def sheet_A2():
    paper_width = to_mils(594)
    paper_height = to_mils(420)
    margin = 400

    return sheet_generator("A2", paper_width, paper_height, margin, margin, 
        range(1, 13), ["A", "B", "C", "D", "E", "F", "G", "H"])

def sheet_A3():
    paper_width = to_mils(420)
    paper_height = to_mils(297)
    margin = 400

    return sheet_generator("A3", paper_width, paper_height, margin, margin, 
        range(1, 9), ["A", "B", "C", "D", "E", "F"])

def sheet_A4():
    paper_width = to_mils(297)
    paper_height = to_mils(210)
    margin = 400

    return sheet_generator("A4", paper_width, paper_height, margin, margin, 
        range(1, 7), ["A", "B", "C", "D"])

def sheet_A5():
    paper_width = to_mils(210)
    paper_height = to_mils(148)
    margin = 400

    return sheet_generator("A5", paper_width, paper_height, margin, margin, range(1, 5), ["A", "B", "C"])

def sheet_A6(revision="V1"):
    paper_width = to_mils(148)
    paper_height = to_mils(105)
    margin = 400

    tmp_sheet = sheet_generator("A6", paper_width, paper_height, margin, margin, range(1, 4), ["A", "B"])
    tmp_sheet.revision = revision

    return tmp_sheet

document.sheet_type = sheet_A4()
document.bom.columns = ["refdes", "mpn", "manufacturer", "footprint"]
document.bom.group_by = ["mpn", "manufacturer"]