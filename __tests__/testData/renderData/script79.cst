# Test correct label text alignment (anchor, vanchor) for different angles and flipxy
from "std" import *

document.sheet_type = sheet_A5()
v33 = supply("3V3")

sheet:
    ..direction = "column"

    frame:
        at led("green") 

        at led("green") angle:90

        at led("green") angle:180

        at led("green") angle:270
    
    frame:
        at led("green") flip:x

        at led("green") flip:x angle:90

        at led("green") flip:x angle:180

        at led("green") flip:x angle:270

    frame:
        at led("green") flip:y

        at led("green") flip:y angle:90

        at led("green") flip:y angle:180

        at led("green") flip:y angle:270

    frame:
        at led("green") flip:xy

        at led("green") flip:xy angle:90

        at led("green") flip:xy angle:180

        at led("green") flip:xy angle:270