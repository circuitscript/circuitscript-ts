# Test net graphical properties (color, lineWidth, highlight)
# Multiple references to the same net name should modify the same net properties

from "std" import *
v3v = supply("3V")
v5 = supply("5V")

gnd = dgnd()

v3v.net.color = "blue"
v3v.net.line_width = 5

at v3v
wire down 100
branch:
    wire right 300 down 100
    add cap(100n)
    wire down 100
    to gnd
wire down 100
add cap(100n)
wire down 100
to gnd

at v3v
wire down 100
add res(1k)
wire down 100
to gnd

# try to reassign
v3v.net.color = "red"
v3v.net.line_width = 1

# use another supply instance with same net name
another = supply("3V")
another.net.color = "purple"
another.net.line_width = 10
another.net.highlight = "red"
another.net.highlight_width = 30
another.net.highlight_opacity = 0.5

at v5
wire down 100
add cap(20n)
wire down 100
to gnd