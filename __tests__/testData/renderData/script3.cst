from "std" import *

vcc = net("3v3")
midpt = net("out")
gnd = dgnd()

frame:
    frame:
        frame:
            frame:
                ..title = "Voltage divider circuit"

                at vcc
                wire down 100
                add res(20k) angle:90
                wire down 100

                branch:
                    wire down 100
                    add res(20k) angle:90
                    wire down 100
                    to gnd
                wire right 60
                to midpt angle:90

            at vcc
            wire down 100
            add res(10k) angle:90
            wire down 100 right 200 up 100
            to midpt