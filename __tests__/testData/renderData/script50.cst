# Test refdes generation is correct for at blocks.
from "std" import *

v5 = supply("5V")
gnd = dgnd()

tmp = create component:
    pins: 
        1: "passive", "A"
        2: "passive", "B"
        3: "passive", "C"
        4: "passive", "D"
        5: "passive", "E"
        6: "passive", "F"
    arrange:
        left: 1,2,3
        right: 4,5,6

at v5
wire down 100 right 100
to tmp pin 1 #= J4

at tmp:
    "A":
        wire left 300 down 100
        branch:
            wire down 100
            add res(10k) #= R3
            wire down 100
            to gnd
            
        branch:
            wire left 300 down 100
            add res(10k) #= R9
            wire down 100
            to gnd

at tmp:
    "E":
        wire right 300 down 100
        add cap(100n) #= C2
        wire down 100
        to gnd

    "F": 
        wire right 100 down 100
        to gnd 