from "std" import *

v5v = supply("5V")
gnd = dgnd()

def led_with_res(label_name):
    add led("yellow") angle:180 pin 2
    add label(label_name)
    wire right 300
    add res(1k)
    wire right 100

join:
    at gnd
    wire right 100
    led_with_res("TXLED")

join:
    at gnd
    wire right 100
    led_with_res("RXLED")
    wire up 300

wire up 100
to v5v