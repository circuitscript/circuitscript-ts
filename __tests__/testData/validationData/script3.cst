import std
document.sheet_type = sheet_A4()

v3v3 = supply("3V3")
v5v = supply("5V")

v5v.color = "blue"
v5v.highlight = "blue"
v5v.highlightWidth = 15

v3v3.color = "red"
v3v3.highlight = "red"
v3v3.highlightWidth = 15

gnd = dgnd()

def merge_point():
    return create component:
        pins: 1
        type: "net"
        display: create graphic (params):
            pin: 1, 0, 0, 0, 0, display_pin_id=false

# create LED array
def led_cell():
    # first join point is here

    branch:
        wire down 100
        add led("YELLOW")
        wire down 100
        add tmp = merge_point()

    wire left 200 down 500
    return tmp


def esp32_c6_wroom():
    return create component:
        type: "ic"
        pins:
            1: power, "GND"
            2: power, "3V3"
            3: input, "EN"

            27: "IO2"
            26: "IO3"

            4: "IO4"
            5: "IO5"
            6: "IO6"
            7: "IO7"
            
            8: "IO0"
            9: "IO1"

            10: "IO8"
            11: "IO10"

            12: "IO11"
            13: "IO12"
            14: "IO13"
            15: "IO9"

            16: "IO18"
            17: "IO19"
            18: "IO20"
            19: "IO21"
            20: "IO22"
            21: "IO23"

            23: "IO15"
            
            24: "RXD0"
            25: "TXD0"

            28: power, "GND"
            


        arrange:
            left: 2, 3, [4], [2], 10, 15, [18], 1, 28
            right: 8, 9 , 11, 12, 16, 17, 18, 19, 20, 21, 23, 26, 27, [2],  25, 24 ,[4], 4, 5, 6, 7, [3], 13, 14

        width: 1000
        params:
            mpn: "ESP32-C6-WROOM-1"

def conn4():
    return create component:
        pins: 4
        arrange:
            left: 1,2,3,4

def conn2():
    return create component:
        pins: 2
        arrange:
            left: 1,2

def push_button():
    return create component:
        pins: 2
        display: create graphic (params):
            hpin: 1, 150, 0, -90
            hpin: 2, -150, 0, 90
            circle: 50, 0, 10
            circle: -50, 0, 10

            line: 60, -30, -60 , -30
            vline: 0, -30, -50

def LDO_TLV75733PDBVR():
    return create component:
        pins: 
            1: input, "IN"
            2: any, "GND"
            3: input, "EN"
            4: any, "NC"
            5: output, "OUT"
        arrange:
            left: 1, 3, 2
            right: 5, [1], 4

        params:
            mpn: "TLV75733PDBVR"

jtag_conn = conn4()
uart_conn = conn4()
usb_conn = conn2()
reset_btn = push_button()

sheet:
    ..title = "ESP32-C6 module"

    frame:
        ..direction = "column"
        ..border = 0
        ..padding = 0

        frame:
            ..title = "Supply"

            at ldo = LDO_TLV75733PDBVR(): #= J5 
                1:
                    point:
                        at v5v
                        wire down 100
                        branch:
                            wire down 100
                            add cap(1u) #= C1
                            wire down 100
                            to gnd

                        wire right 500
                        to point
                3:
                    wire left 100 auto
                    to pin 1
                
                2:
                    wire left 100 down 200
                    to gnd

                
                5:
                    wire right 300 
                    branch: 
                        wire down 100
                        add cap(1u) #= C2
                        wire down 100
                        to gnd

                    wire right 100 up 100
                    to v3v3

                4:
                    add no_connect() #= J6


            at v3v3
            wire down 100
            add led("GREEN") #= D1
            wire down 100
            add res(4.7k) #= R1
            wire down 100
            to gnd
        

        # For EN signal
        frame:
            ..title = "Enable signal"

            at label("EN")
            wire right 300
            branch:
                wire up 100
                add res(10k) #= R2
                wire up 100
                to v3v3

            wire down 100

            parallel:
                wire down 100
                add reset_btn #= J4
                wire down 100

            parallel:
                wire right 200 down 200
                add cap(100n) #= C3
                wire auto

            wire down 100
            to gnd

    frame: 
        ..title = "ESP32-C6 Module"

        at esp32_module = esp32_c6_wroom(): #= U1
            "3V3":
                wire left 400 
                branch:
                    wire down 100
                    add cap(100n) #= C4
                    wire down 100
                    to gnd

                wire left 300
                branch:
                    wire down 100
                    add cap(22u) #= C5
                    wire down 100
                    to gnd

                wire left 100
                wire up 100
                to v3v3

            "EN":
                wire left 100
                add label("EN")

            "IO8": 
                wire left 100
                add res(10k) #= R3


                add text("Boot mode", 0, -120)

                wire left 100
                to v3v3

            "IO9":
                wire left 300 down 100
                add res(0) #= R4
                wire down 100
                to gnd

            1:
                wire left 100 down 100
                branch:
                    wire auto 
                    to pin 28
                wire down 100
                to gnd

            "IO4":
                wire right 100 
                add label("TMS")
                add text("JTAG connection", 0, -100)
                wire right 900
                to jtag_conn pin 1 #= J1
            "IO5":
                wire right 100
                add label("TDI")
                wire auto to jtag_conn pin 2
            "IO6":
                wire right 100
                add label("TCK")
                wire auto to jtag_conn pin 3
            "IO7": 
                wire right 100
                add label("TDO")
                wire auto to jtag_conn pin 4

            "TXD0": 
                wire right 100
                add label("TXD0")

                add text("UART connection", 0, -100)

                wire right 700
                to uart_conn pin 2 #= J2

            "RXD0":
                wire right 100
                add label("RXD0")
                wire auto
                to uart_conn pin 3

            "IO12":
                wire right 100
                add label("USB_D+")
                wire right 300
                add res(0) #= R5
                wire right 100
                branch:
                    wire down 200
                    add cap(100n) #= C6
                    ..place = false
                    ..flipX = true

                    wire down 100
                    to gnd
                wire right 300
                to usb_conn #= J3

            "IO13":
                wire right 100
                add label("USB_D-")
                wire right 300 
                
                add res(0) #= R6
                ..flipY = true
                
                wire right 300
                branch:
                    wire down 100
                    add cap(100n) #= C7
                    ..place = false
                    wire down 100
                    to gnd
                wire auto 
                to usb_conn pin 2

            "IO2":
                add no_connect() #= J7

        counter = 1
        for i in [0, 1, 10, 11, 18, 19]:
            at esp32_module pin ("IO" + i)
            wire right 100 
            add label("ROW" + counter)
            wire right 200
            counter += 1

        counter = 1
        for i in [20, 21, 22, 23, 15, 3]:
            at esp32_module pin ("IO" + i)
            wire right 100
            add label("COL" + counter)
            wire right 200
            counter += 1

        at uart_conn:
            1:
                wire left 100 up 100 to v3v3
            4:
                wire left 100 down 100 to gnd

    frame:
        ..title = "LED array"

        # store the previous merge point
        tmp_array = [0, 0, 0, 0, 0, 0, 0]

        for j in range(1, len(tmp_array)):
            at label("COL" + j)
            wire right 200 down 200

            for i in range(1, len(tmp_array)):
                wire down 100
                branch:
                    wire down 100
                    add led("YELLOW") #= D2_
                    wire down 100
                    add tmp = merge_point()

                    if arrayGet(tmp_array, i-1) == 0:
                        wire left 500
                        add label("ROW" + i)
                    else:
                        wire left 400
                        to arrayGet(tmp_array, i-1, tmp)

                    arraySet(tmp_array, i-1, tmp)

                if i < (len(tmp_array)-1):
                    wire left 200 down 600 right 200

                