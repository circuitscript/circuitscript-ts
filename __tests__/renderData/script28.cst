# Test component width and height prop

import lib
vcc = supply("VCC")
gnd = dgnd()

tmp = create component:
    pins: 8
    width: 500
    height: 500
    arrange:
        left:   1,2
        top:    3, 4
        right:  5, 6
        bottom: 7, 8


at vcc 
wire down 100
branch:
    wire down 100
    to tmp pin 4

wire auto_
to tmp pin 3

at tmp pin 8
wire down 100
branch:
    wire auto
    to tmp pin 7

wire down 100
to gnd