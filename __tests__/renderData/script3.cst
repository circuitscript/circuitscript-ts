import lib

vcc = net("3v3")
midpt = net("out")
gnd = dgnd()

frame:
    frame:
        frame:
            frame:
                ..title = "Voltage divider circuit"

                at vcc
                wire down 20
                add res(20k) down
                wire down 20

                branch:
                    wire down 20
                    add res(20k) down
                    wire down 20
                    to gnd
                wire right 60
                to midpt right

            at vcc
            wire down 20
            add res(10k) down
            wire down 20 right 40 up 20
            to midpt