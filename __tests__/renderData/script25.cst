# Tests that a custom symbol is able to support blank spaces at the 
# start and end of the arrange prop

import lib
vcc = supply("VCC")
gnd = dgnd()

tmp = create component:
    pins: 8
    arrange:
        left:   [3], 1, 2
        top:    [1], 3, 4, [5]
        right:  5, 6, [10]
        bottom: [1], 7, 8, [5]


at vcc 
wire down 100
branch:
    wire down 100
    to tmp pin 4

wire auto_
to tmp pin 3

at tmp pin 8
wire down 100
branch:
    wire auto
    to tmp pin 7

wire down 100
to gnd