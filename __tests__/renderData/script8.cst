# Test `point` keyword

import lib

v5v = supply("5V")
gnd = dgnd()

at v5v
wire down 100
add res(360) angle:90
wire down 100

point:
    at v5v
    wire down 100
    add res(360) angle:90
    wire down 100

    branch:
        wire left 500
        to point

    wire down 100
    add res(360) angle:90
    wire down 200
    to gnd

    at point
    wire right 1000 down 100
    add res(360) angle:90
    wire down 200
    to gnd

wire down 100
add led("red") angle:90
wire down 100
to gnd