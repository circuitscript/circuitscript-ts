{
  "compilerOptions": {
    "lib": [
      "esnext"
    ],
    "module": "commonjs",
    "outDir": "./dist/cjs",
    "target": "es2020",
    "declaration": true,
    "declarationDir": "./dist/types",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "rootDir": "./src",
    "sourceMap": true
  },
  "include": [
    "src",
    "__tests__",
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}